# 复制为 .env 并填入实际值

# ---------- 基础 ----------
PORT=8089
MONGODB_URI=mongodb://localhost:27017/personal-blog

# JWT — 必填,随机长字符串(建议 64+ 字节)
JWT_SECRET=change-me-to-a-long-random-string
# 普通(GitHub)用户 JWT 有效期,可选,默认 30d
JWT_EXPIRE=30d

# 部署环境(production 时启用 cookie secure 标志等)
NODE_ENV=development

# ---------- GitHub OAuth ----------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Callback URL 三选一(优先级从上到下):
#   1) 直接给完整 URL — 优先级最高
GITHUB_CALLBACK_URL=http://localhost:8089/api/auth/github/callback
#   2) 只给后端根域名,自动拼成 <BACKEND_URL>/api/auth/github/callback
# BACKEND_URL=https://api.your-domain.com
#   3) 都不填 → 回退到 http://localhost:${PORT}/api/auth/github/callback

# 前端地址 — 用于 OAuth 回跳重定向 + 评论/点赞 Origin 校验
FRONTEND_URL=http://localhost:5173

# ---------- Cloudflare Turnstile (可选) ----------
# 未填或保留占位符时,Turnstile 验证会自动跳过
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=

# ---------- 管理员凭据 ----------
# 邮箱格式会被直接当作 username + email 使用;非邮箱字符串则自动追加 @local.admin
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# ---------- AI 评论审核 (可选) ----------
# Google AI Studio API key,逗号分隔多 key 自动轮询
# 每个 (key, 模型) 各自限 RPM=10 / RPD=1500
# 留空 → 审核停用,评论直接发布(其它反滥用层照常生效)
GEMINI_API_KEYS=
